# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Optional defaults for soccer analysis
ANALYSIS_MODE=goalkeeper_review
OUTPUT_DIR=results
UPLOADS_DIR=uploads
ATHLETES_DIR=athletes
MAX_INLINE_BYTES=20000000

# Optional cloud persistence mode (enable both DATABASE_URL and S3_BUCKET)
DATABASE_URL=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
